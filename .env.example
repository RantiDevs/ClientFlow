# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgres://username:password@localhost:5432/clientflow
# Hosted:  Use your Neon / Supabase / Railway connection string
DATABASE_URL=postgres://username:password@localhost:5432/clientflow

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Token expiry (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express API listens on during local development
BACKEND_PORT=3001

# Set to "production" when deploying
NODE_ENV=development

# ─── Email (optional) ─────────────────────────────────────────────────────────
# If not set, the server runs in dev mode and returns verification codes
# directly in the API response instead of sending emails.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=noreply@clientflow.app
